# ============================================================
# InfraNaut AI — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── OpenRouter (AI) ───────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Used by: Nexora AI, Eco-Routes, Analytics, Tourism AI
VITE_OPENROUTER_API_KEY=sk-or-v1-...

# ── Express Backend ───────────────────────────────────────────
# The Express server handles: Socket.IO, email, file uploads
VITE_BACKEND_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# ── Email API ─────────────────────────────────────────────────
# MUST match server/.env EMAIL_API_KEY exactly
VITE_EMAIL_API_KEY=infranaut-email-secret-2025

# ── AnythingLLM (optional RAG layer) ─────────────────────────
# If not running, the system automatically falls back to OpenRouter
VITE_ANYLLM_URL=http://localhost:3001
VITE_ANYLLM_KEY=your_anythingllm_key
